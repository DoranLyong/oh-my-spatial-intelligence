      "boundElements": [],
      "updated": 1779268786049,
      "link": null,
      "locked": false,
      "text": "Interactive asset generation must be rooted in\nFUNCTIONAL LOGIC and HIERARCHICAL PHYSICS.\n\nAn object's structure is a manifestation of its\nintended physical functions — a handle exists\nbecause something grasps it, a hinge because\nsomething opens.",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Interactive asset generation must be rooted in\nFUNCTIONAL LOGIC and HIERARCHICAL PHYSICS.\n\nAn object's structure is a manifestation of its\nintended physical functions — a handle exists\nbecause something grasps it, a hinge because\nsomething opens.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11
    },
