    {
      "id": "tqn62tOy4CqpIqK3",
      "type": "text",
      "x": 80,
      "y": 146,
      "width": 483.4615478515625,
      "height": 122.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
