    {
      "id": "zuLWOefQrSO42uKi",
      "type": "text",
      "x": 1615,
      "y": 1390,
      "width": 740,
      "height": 292.59999999999997,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
