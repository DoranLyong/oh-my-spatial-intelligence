      "index": "a4",
      "roundness": null,
      "seed": 857706060,
      "version": 32,
      "versionNonce": 1460832494,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779268786049,
      "link": null,
      "locked": false,
      "text": "Existing 3D generators (TRELLIS, CLAY, DreamFusion family) produce\nhigh-fidelity geometry — but the outputs are HOLLOW SHELLS:\n\n  ✗ no material / mass / function annotation\n  ✗ no kinematic joint definitions\n  ✗ cannot be grasped, pushed, or articulated\n  ✗ unusable in embodied AI simulators / game engines",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Existing 3D generators (TRELLIS, CLAY, DreamFusion family) produce\nhigh-fidelity geometry — but the outputs are HOLLOW SHELLS:\n\n  ✗ no material / mass / function annotation\n  ✗ no kinematic joint definitions\n  ✗ cannot be grasped, pushed, or articulated\n  ✗ unusable in embodied AI simulators / game engines",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11
    },
